{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Audit": {
    "Sink": "efcore",
    "EnforceAuditableSetting": false,
    "Database": {
      "Provider": "sqlite",
      "ConnectionString": "Data Source=sample-audit.db"
    }
  }
}
